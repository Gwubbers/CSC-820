{
  "info": {
    "name": "Order Management API",
    "description": "Complete test collection for the Order Management RESTful API. Tests all five endpoints including happy path and error cases.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string",
      "description": "Populated automatically by the POST /orders test script"
    }
  ],
  "item": [
    {
      "name": "1. Create Order (Happy Path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
              "pm.test('Response has order object', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.order).to.be.an('object');",
              "  pm.expect(json.order.id).to.be.a('string');",
              "  pm.expect(json.order.status).to.equal('Pending');",
              "  pm.collectionVariables.set('orderId', json.order.id);",
              "});",
              "pm.test('Response has transactionId', () => {",
              "  pm.expect(pm.response.json().transactionId).to.be.a('string');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer\": \"Jane Smith\",\n  \"product\": \"Wireless Keyboard\",\n  \"quantity\": 2\n}"
        },
        "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] }
      }
    },
    {
      "name": "2. Create Order — Missing Fields (Error Case)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400', () => pm.response.to.have.status(400));",
              "pm.test('Error message is present', () => {",
              "  pm.expect(pm.response.json().error).to.be.a('string');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer\": \"Jane Smith\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] }
      }
    },
    {
      "name": "3. Get All Orders (Happy Path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response has orders array', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.orders).to.be.an('array');",
              "  pm.expect(json.count).to.be.a('number');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] }
      }
    },
    {
      "name": "4. Get Single Order (Happy Path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
              "pm.test('Order ID matches', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.id).to.equal(pm.collectionVariables.get('orderId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/orders/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["orders", "{{orderId}}"]
        }
      }
    },
    {
      "name": "5. Get Order — Not Found (Error Case)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', () => pm.response.to.have.status(404));",
              "pm.test('Error message is present', () => {",
              "  pm.expect(pm.response.json().error).to.include('not found');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/orders/00000000-0000-0000-0000-000000000000",
          "host": ["{{baseUrl}}"],
          "path": ["orders", "00000000-0000-0000-0000-000000000000"]
        }
      }
    },
    {
      "name": "6. Update Order Status (Happy Path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is updated to Shipped', () => {",
              "  pm.expect(pm.response.json().order.status).to.equal('Shipped');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"Shipped\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/orders/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["orders", "{{orderId}}"]
        }
      }
    },
    {
      "name": "7. Update Order Status — Invalid Status (Error Case)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400', () => pm.response.to.have.status(400));",
              "pm.test('Error message mentions invalid status', () => {",
              "  pm.expect(pm.response.json().error).to.include('Invalid status');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"Exploded\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/orders/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["orders", "{{orderId}}"]
        }
      }
    },
    {
      "name": "8. Delete Order (Happy Path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
              "pm.test('Deletion confirmed', () => {",
              "  pm.expect(pm.response.json().message).to.include('deleted');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/orders/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["orders", "{{orderId}}"]
        }
      }
    },
    {
      "name": "9. Delete Order — Already Deleted (Error Case)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', () => pm.response.to.have.status(404));",
              "pm.test('Error message is present', () => {",
              "  pm.expect(pm.response.json().error).to.include('not found');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/orders/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["orders", "{{orderId}}"]
        }
      }
    }
  ]
}
